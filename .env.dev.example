# =============================================================================
# atl.chat local development overrides (.env.dev.example)
# Copy to .env.dev. These values override .env only for `just dev`.
# =============================================================================

# Keep stack local-only during development
ATL_CHAT_IP=127.0.0.1
ATL_GATEWAY_IP=127.0.0.1

# Local domains/certs
IRC_DOMAIN=irc.localhost
XMPP_DOMAIN=xmpp.localhost
PROSODY_DOMAIN=xmpp.localhost
IRC_SSL_CERT_PATH=/home/unrealircd/unrealircd/certs/live/irc.localhost/fullchain.pem
IRC_SSL_KEY_PATH=/home/unrealircd/unrealircd/certs/live/irc.localhost/privkey.pem

# Explicit dev security behavior
IRC_TLS_VERIFY=false
IRC_LOUNGE_REJECT_UNAUTHORIZED=false
IRC_WEBSOCKET_USE_TLS=true
BRIDGE_IRC_TLS_VERIFY=false

# Prosody dev behavior for self-signed/local setup
PROSODY_ALLOW_PLACEHOLDER_KEY=true
PROSODY_HTTPS_VIA_PROXY=false
PROSODY_UPLOAD_EXTERNAL_URL=https://xmpp.localhost:5281/upload/
PROSODY_HTTP_EXTERNAL_URL=http://xmpp.localhost:5280/
PROSODY_PROXY_ADDRESS=xmpp.localhost
PROSODY_SSL_KEY=/etc/prosody/certs/live/xmpp.localhost/privkey.pem
PROSODY_SSL_CERT=/etc/prosody/certs/live/xmpp.localhost/fullchain.pem

PROSODY_C2S_REQUIRE_ENCRYPTION=false
PROSODY_S2S_REQUIRE_ENCRYPTION=false
PROSODY_S2S_SECURE_AUTH=false
PROSODY_ALLOW_UNENCRYPTED_PLAIN_AUTH=true

# Bridge local defaults
BRIDGE_XMPP_COMPONENT_JID=bridge.xmpp.localhost
BRIDGE_PORTAL_BASE_URL=
BRIDGE_RELAYMSG_CLEAN_NICKS=true
LOG_LEVEL=DEBUG

# Docker-internal URLs for bridge media/avatar checks
XMPP_AVATAR_BASE_URL=http://atl-xmpp-server:5280
XMPP_UPLOAD_FETCH_URL=http://atl-xmpp-server:5280

# Local frontend endpoints
NEXT_PUBLIC_IRC_WS_URL=wss://irc.localhost/ws
NEXT_PUBLIC_XMPP_BOSH_URL=https://xmpp.localhost/http-bind

# Portal identity for bridge (must match portal BRIDGE_SERVICE_TOKEN)
# BRIDGE_PORTAL_BASE_URL=http://host.docker.internal:3000
# BRIDGE_PORTAL_TOKEN=dev-bridge-token-change-me

# Prosody HTTP admin API token (portal provisioning); generate: just prosody-token
# PROSODY_REST_URL=http://atl-xmpp-server:5280
# PROSODY_REST_TOKEN=

# Optional local-only bridge puppets (no Portal)
# BRIDGE_DEV_IRC_PUPPETS=true
# BRIDGE_DEV_IRC_NICK_MAP={"123456789012345678":"your_nick"}
